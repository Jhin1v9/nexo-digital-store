{
  "_schema": {
    "description": "Configuracao de crop/posicao das thumbnails da NEXO Store",
    "priority": "bySlug > byType > default",
    "fields": {
      "v_align": "top | center | bottom (onde a imagem e ancora verticalmente no crop)",
      "h_align": "left | center | right",
      "zoom": "fator de escala, ex: 1.0 = original, 1.2 = 20% zoom in, 0.8 = zoom out",
      "offset_y_percent": "deslocamento extra vertical apos o alinhamento (-50 a +50)",
      "offset_x_percent": "deslocamento extra horizontal apos o alinhamento (-50 a +50)",
      "source": "pdf | local | vercel | placeholder (apenas documentacao)"
    }
  },
  "default": {
    "v_align": "top",
    "h_align": "center",
    "zoom": 1.0,
    "offset_y_percent": 0,
    "offset_x_percent": 0
  },
